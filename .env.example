# --------------------------
# Authentication (Required if REQUIRE_AUTH=true)
# --------------------------
PROXY_USER=someuser
PROXY_PASSWORD=somepass

# --------------------------
# General Server Settings
# --------------------------
# PROXY_PORT=1080
# PROXY_LISTEN_IP=0.0.0.0
# REQUIRE_AUTH=true

# --------------------------
# Access Control Lists (ACL)
# --------------------------
# ALLOWED_DEST_FQDN=
# ALLOWED_IPS=

# --------------------------
# Timeouts & Limits
# --------------------------
# READ_TIMEOUT=30s
# WRITE_TIMEOUT=30s
# MAX_CONNECTIONS=10000

# --------------------------
# Security Limits (Fail2Ban)
# --------------------------
# FAIL2BAN_RETRIES=5
# FAIL2BAN_TIME=5m

# --------------------------
# Observability
# --------------------------
# METRICS_PORT=8080
